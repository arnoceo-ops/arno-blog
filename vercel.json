{
  "crons": [
    {
      "path": "/api/cron/weekly-nudge",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/auto-analyse",
      "schedule": "0 3 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://arno.bot/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "royaldutchsales.com"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://arno.bot/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.royaldutchsales.com"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/canvas",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": "canvas.royaldutchsales.com"
        }
      ]
    }
  ]
}